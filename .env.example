APP_ENV=local
API_HOST=0.0.0.0

# ==========================================
# Network Port Configurations (Customize if ports clash with other projects)
# ==========================================
API_PORT=8000           # FastAPI serving endpoints port
POSTGRES_PORT=5432      # PostgreSQL database port
MLFLOW_PORT=5001        # MLflow server tracking port
GRAFANA_PORT=3001       # Grafana dashboard port
DASHBOARD_PORT=3000     # React dashboard UI port

POSTGRES_USER=fraudshield
POSTGRES_PASSWORD=fraudshield
POSTGRES_DB=fraudshield
POSTGRES_HOST=localhost
DATABASE_URL=postgresql://fraudshield:fraudshield@localhost:5432/fraudshield

MLFLOW_TRACKING_URI=http://localhost:5001
MLFLOW_BACKEND_STORE_URI=postgresql://fraudshield:fraudshield@localhost:5432/fraudshield
MLFLOW_ARTIFACT_ROOT=./models/mlflow

MODEL_NAME=fraudshield-xgboost
MODEL_STAGE=Production
CONFIG_PATH=config/config.yaml
